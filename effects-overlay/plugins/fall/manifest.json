    },
    {
      "key": "scale",
      "type": "slider",
      "label": "サイズ",
      "min": 10,
      "max": 300,
      "default": 100,
      "suffix": "%"
    }
  ],
  "badgeColor": {
    "bg": "#1e3a5f",
    "fg": "#60a5fa"
  }
