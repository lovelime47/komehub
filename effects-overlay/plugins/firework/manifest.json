      "key": "fwOpacity",
      "type": "slider",
      "label": "花火の透明度",
      "hint": "花火全体の不透明度。下げるほど配信画面が透けます。",
      "min": 20,
      "max": 100,
      "step": 1,
      "default": 80,
      "suffix": "%",
      "group": "表示"
    },
    {
      "key": "fwNoZone",
      "type": "toggle",
      "label": "中心の発射禁止帯",
      "hint": "画面中央を縦に避けて花火を左右へ出します（配信者やメイン映像を覆わない）。",
      "default": true,
      "onLabel": "ON",
      "offLabel": "OFF",
      "group": "表示"
    },
    {
      "key": "fwNoZoneWidth",
      "type": "slider",
      "label": "禁止帯の幅",
      "hint": "中央を空ける帯の幅（画面幅に対する割合）。",
      "min": 0,
      "max": 85,
      "step": 1,
      "default": 36,
      "suffix": "%",
      "showIf": { "key": "fwNoZone", "value": true },
      "group": "表示"
    }
