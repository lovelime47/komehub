{
  "id": "com.comment-hub.firework",
  "version": "2.0.0",
  "name": "花火",
  "emoji": "🎆",
  "entry": "firework.js",
  "globalName": "Firework",
  "interface": {
    "methods": [
      "fire"
    ],
    "hasPause": false
  },
  "defaultAssets": [],
