    "duration": 6000,
    "tier_blue": ["small"],
    "tier_teal": ["small"],
    "tier_green": ["small", "medium"],
    "tier_yellow": ["medium"],
    "tier_orange": ["medium", "large"],
    "tier_magenta": ["large"],
    "tier_red": ["large", "grand"],
    "nonScShows": ["small", "medium"],
    "fwOpacity": 80,
    "fwNoZone": true,
    "fwNoZoneWidth": 36
  },
  "dependencies": [],
  "migrations": {},
