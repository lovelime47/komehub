{
  "id": "com.comment-hub.template.frame-neon-cyber",
  "name": "frame-neon-cyber",
  "displayName": "ネオンサイバー",
  "version": "1.0.0",
  "obsHint": "OBS幅 460px 前後 / 高さは任意。マゼンタ + シアンのネオンフレーム",
  "fonts": ["Orbitron", "Noto Sans JP"],
  "exportPolicy": {
    "allowTemplateExport": true,
    "note": "framed-list-renderless 派生。ネオンサイバー演出。"
  },
  "uiSchema": [
    { "key": "maxComments", "type": "slider", "label": "最大表示数", "min": 3, "max": 30, "step": 1, "default": 8 },
    { "key": "width", "type": "slider", "label": "フレーム幅", "min": 320, "max": 720, "step": 10, "default": 460, "suffix": "px" },
    { "key": "frameHeight", "type": "slider", "label": "フレーム高さ", "min": 220, "max": 1200, "step": 10, "default": 600, "suffix": "px" },
    { "key": "fontSize", "type": "slider", "label": "文字サイズ", "min": 12, "max": 30, "step": 1, "default": 18, "suffix": "px" },
    { "key": "colorPreset", "type": "buttons", "label": "色プリセット (選ぶと下の個別色を上書きします)", "default": "magenta-cyan", "options": [
      { "value": "magenta-cyan", "label": "マゼンタ×シアン", "applyValues": {
        "accentColor": "#ff00ff", "secondaryColor": "#00ffff",
        "textColor": "#ffffff", "bgColor": "#0a0010",
        "highlightColor": "#ffec40", "borderColor": "#ff00ff"
      }},
      { "value": "lime-magenta", "label": "ライム×マゼンタ", "applyValues": {
        "accentColor": "#5fff5f", "secondaryColor": "#ff5fff",
        "textColor": "#ffffff", "bgColor": "#000a00",
        "highlightColor": "#ffec40", "borderColor": "#5fff5f"
      }},
      { "value": "orange-cyan", "label": "オレンジ×シアン", "applyValues": {
        "accentColor": "#ff8800", "secondaryColor": "#00ffff",
        "textColor": "#ffffff", "bgColor": "#100600",
        "highlightColor": "#ffec40", "borderColor": "#ff8800"
      }},
      { "value": "purple-pink", "label": "パープル×ピンク", "applyValues": {
        "accentColor": "#a020f0", "secondaryColor": "#ff80c0",
        "textColor": "#ffffff", "bgColor": "#0a0015",
        "highlightColor": "#ffec40", "borderColor": "#a020f0"
      }},
      { "value": "yellow-cyan", "label": "イエロー×シアン", "applyValues": {
        "accentColor": "#ffec40", "secondaryColor": "#00ffff",
        "textColor": "#ffffff", "bgColor": "#0a0a00",
        "highlightColor": "#ff5f5f", "borderColor": "#ffec40"
      }}
    ]},
    { "key": "accentColor", "type": "color", "label": "アクセント色 (枠)", "default": "#ff00ff" },
    { "key": "secondaryColor", "type": "color", "label": "セカンダリ色 (名前)", "default": "#00ffff" },
    { "key": "textColor", "type": "color", "label": "本文の色", "default": "#ffffff" },
    { "key": "bgColor", "type": "color", "label": "背景色", "default": "#0a0010" },
    { "key": "highlightColor", "type": "color", "label": "強調色 (金額)", "default": "#ffec40" },
    { "key": "borderColor", "type": "color", "label": "枠線・区切り色", "default": "#ff00ff" },
    { "key": "frameOpacity", "type": "slider", "label": "背景濃度", "min": 0.2, "max": 1, "step": 0.05, "default": 0.85 },
    { "key": "showAvatar", "type": "toggle", "label": "アバター表示", "default": false, "onLabel": "表示", "offLabel": "非表示" },
    { "key": "showBadge", "type": "toggle", "label": "メンバーバッジ表示", "default": true, "onLabel": "表示", "offLabel": "非表示" },
    { "key": "memberColor", "type": "toggle", "label": "メンバー名を色分け", "default": true, "onLabel": "ON", "offLabel": "OFF" },
    { "key": "memberColorValue", "type": "color", "label": "メンバー名の色", "default": "#80ff80", "showIf": { "key": "memberColor", "value": true } },
    { "key": "showHeader", "type": "toggle", "label": "ヘッダー表示", "default": true, "onLabel": "表示", "offLabel": "非表示" },
    { "key": "kickerText", "type": "text", "label": "ヘッダー上の小ラベル", "default": "CYBER", "showIf": { "key": "showHeader", "value": true } },
    { "key": "headerText", "type": "text", "label": "ヘッダータイトル", "default": "NEXUS-77", "showIf": { "key": "showHeader", "value": true } },
    { "key": "showFooter", "type": "toggle", "label": "フッター表示", "default": true, "onLabel": "表示", "offLabel": "非表示" },
    { "key": "footerText", "type": "text", "label": "フッターテキスト", "default": "node://komehub", "showIf": { "key": "showFooter", "value": true } },
    { "key": "dense", "type": "toggle", "label": "コンパクト表示", "default": false, "onLabel": "ON", "offLabel": "OFF" },
    { "key": "animationStyle", "type": "buttons", "label": "アニメーション", "default": "slide-up", "options": [
      { "value": "slide-up", "label": "下から" },
      { "value": "slide-left", "label": "右から" },
      { "value": "scale-in", "label": "ズーム" },
      { "value": "none", "label": "なし" }
    ]},
    { "key": "customCss", "type": "textarea", "label": "カスタムCSS", "placeholder": ".frame-shell { box-shadow: 0 0 20px #ff00ff; }" }
  ]
}
