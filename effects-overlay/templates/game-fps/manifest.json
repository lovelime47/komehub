{
  "id": "com.comment-hub.template.game-fps",
  "name": "game-fps",
  "displayName": "FPS",
  "version": "1.0.0",
  "obsHint": "FPS/アクションゲーム向けの高視認・密集表示。OBS幅 480px 推奨 / 高さは任意",
  "fonts": ["BIZ UDGothic", "Noto Sans JP"],
  "uiSchema": [
    { "key": "maxComments", "type": "slider", "label": "最大表示数", "min": 5, "max": 50, "step": 1, "default": 20 },
    { "key": "fontSize", "type": "slider", "label": "文字サイズ", "min": 8, "max": 60, "default": 24, "suffix": "px" },
    { "key": "showName", "type": "toggle", "label": "名前表示", "default": true, "onLabel": "表示", "offLabel": "非表示" },
    { "key": "nameInline", "type": "toggle", "label": "名前を本文と同じ行に", "default": true, "onLabel": "同じ行", "offLabel": "2行" },
    { "key": "showAvatar", "type": "toggle", "label": "アバター表示", "default": false, "onLabel": "表示", "offLabel": "非表示" },
    { "key": "showBadge", "type": "toggle", "label": "バッジ表示", "default": false, "onLabel": "表示", "offLabel": "非表示" },
    { "key": "direction", "type": "buttons", "label": "流れる方向", "options": [{ "value": "up", "label": "↑ 上へ" }, { "value": "down", "label": "↓ 下へ" }], "default": "up" },
    { "key": "nameColor", "type": "color", "label": "名前の色", "default": "#6ea8d4" },
    { "key": "textColor", "type": "color", "label": "コメントの色", "default": "rgba(255,255,255,0.82)" },
    { "key": "memberColor", "type": "toggle", "label": "メンバーシップ色分け", "default": false, "onLabel": "ON", "offLabel": "OFF" },
    { "key": "memberColorValue", "type": "color", "label": "メンバーの名前色", "default": "#2ba640", "showIf": { "key": "memberColor", "value": true } }
  ]
}
